# ── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=sarelia_db

# ── JWT ──────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_secret_string
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Bcrypt ───────────────────────────────────────
BCRYPT_ROUNDS=12
